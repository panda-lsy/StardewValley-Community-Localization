{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svl.local/schemas/mod.schema.json",
  "title": "SVL Mod Localization",
  "type": "object",
  "required": [
    "schemaVersion",
    "entityType",
    "platform",
    "id",
    "name",
    "description"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "entityType": { "type": "string", "const": "mod" },
    "platform": { "type": "string", "enum": ["Curseforge", "NexusMods"] },
    "id": { "type": "string", "minLength": 1 },
    "name": {
      "type": "object",
      "required": ["zh-CN"],
      "properties": {
        "zh-CN": { "type": "string", "minLength": 1 },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "description": {
      "type": "object",
      "required": ["zh-CN"],
      "properties": {
        "zh-CN": { "type": "string", "minLength": 1 },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "optional"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "optional": { "type": "boolean" },
          "note": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "hardConflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "functionalOverlaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "contributor": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
